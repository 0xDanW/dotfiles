" enable syntax highlighting
syntax on

" enable line numbers
set nu

" set UTF-8 encoding
set encoding=UTF-8

" enable smart tab and indentations
set smarttab
set smartindent

" set number of spaces to indent within a code block
set tabstop=4 softtabstop=4
set shiftwidth=4

" replace tab chars with spaces
set expandtab

" prevent new swap files when opening existing files in vim
set noswapfile

" highlight text when searching with `/`
set incsearch

" keeps cursor size for INSERT mode
set guicursor
